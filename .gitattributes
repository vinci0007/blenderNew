# Auto detect text files and perform LF normalization
* text=auto

# Keep source and configuration files stable across Windows/macOS/Linux.
*.py text eol=lf
*.toml text eol=lf
*.toml.example text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
